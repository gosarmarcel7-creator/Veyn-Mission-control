# Web / production
NEXT_PUBLIC_VEYN_DEMO_MODE=false

# Desktop app (also set automatically by Electron main process)
# VEYN_DESKTOP=1
# VEYN_LOCAL_DB=1
# VEYN_DATA_DIR=
# NEXT_PUBLIC_VEYN_DESKTOP=1

# Workspace routing
VEYN_WORKSPACE_ID=ws_prod
NEXT_PUBLIC_VEYN_WORKSPACE_ID=ws_prod
NEXT_PUBLIC_VEYN_WEBHOOK_ID=wh_prod
NEXT_PUBLIC_VEYN_WEBHOOK_SECRET_HINT=stored-in-server-secret-manager

# Optional: encryption key for stored API keys (server-side)
# VEYN_SECRET_KEY=

# Supabase server credentials (optional cloud sync)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# GitHub Releases link shown in web UI when terminals are unavailable
NEXT_PUBLIC_GITHUB_REPO=https://github.com/gosarmarcel7-creator/ai-agent-mission-control
