{
  "name": "ai-agent-mission-control",
  "version": "0.1.0",
  "description": "Veyn — spatial command center for multi-agent operations with desktop terminals",
  "author": "Veyn",
  "license": "MIT",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev",
    "dev:desktop": "npm run build && npm run electron:prepare && cross-env VEYN_DESKTOP=1 VEYN_LOCAL_DB=1 electron .",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:prepare": "node scripts/prepare-electron-standalone.mjs",
    "electron:dev": "npm run build && npm run electron:prepare && cross-env VEYN_DESKTOP=1 VEYN_LOCAL_DB=1 electron .",
    "electron:dist": "npm run build && npm run electron:prepare && electron-builder",
    "seed:local": "node scripts/seed-local.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@supabase/supabase-js": "^2.106.1",
    "@tanstack/react-query": "^5.100.13",
    "@types/three": "^0.184.1",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "node-pty": "^1.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "shadcn": "^4.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "three": "^0.184.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^7.0.3",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "build": {
    "appId": "io.veyn.mission-control",
    "productName": "Veyn",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "standalone",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": ["nsis"]
    },
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": ["AppImage"]
    }
  }
}
